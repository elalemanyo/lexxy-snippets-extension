    "node": ">=20.19"
  },
  "peerDependencies": {
    "@37signals/lexxy": ">=0.9.25 <1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "eslint": "^9.39.5",
    "neostandard": "^0.13.0"
