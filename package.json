{
  "name": "lexxy-snippets-extension",
  "version": "0.1.0",
  "description": "Snippets toolbar extension for Lexxy editors.",
  "type": "module",
  "main": "./snippets_extension.js",
  "types": "./snippets_extension.d.ts",
  "exports": {
    ".": {
      "types": "./snippets_extension.d.ts",
      "import": "./snippets_extension.js",
      "default": "./snippets_extension.js"
    }
  },
  "files": [
    "snippets_extension.js",
    "snippets_extension.d.ts",
    "README.md"
  ],
  "scripts": {
